---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const features = [
  lang === 'en' ? 'Real-time activity booking' : lang === 'de' ? 'Echtzeit-Buchung' : lang === 'es' ? 'Reserva en tiempo real' : 'Reserva d\'activitats en temps real',
  lang === 'en' ? 'QR entry to facilities' : lang === 'de' ? 'QR-Zutritt' : lang === 'es' ? 'QR de acceso' : 'QR d\'accés a les instal·lacions',
  lang === 'en' ? 'Booking history' : lang === 'de' ? 'Buchungsverlauf' : lang === 'es' ? 'Historial de reservas' : 'Historial de reserves',
  lang === 'en' ? 'Class notifications' : lang === 'de' ? 'Kursbenachrichtigungen' : lang === 'es' ? 'Notificaciones' : 'Notificacions de classes',
  lang === 'en' ? 'Training tracking (Trainingym)' : lang === 'de' ? 'Trainingsverfolgung' : lang === 'es' ? 'Seguimiento entrenamiento' : 'Seguiment entrenament (Trainingym)',
];
---

<section class="section pool-bg text-white relative overflow-hidden" aria-labelledby="app-heading">
  <!-- Decorative -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full translate-y-1/3 -translate-x-1/3"></div>

  <div class="container-site relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Content -->
      <div>
        <span class="badge bg-white/20 text-white border border-white/30 mb-4">
          <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
          {t('app.badge')}
        </span>
        <h2 id="app-heading" class="font-display font-bold text-4xl text-white mb-4">
          {t('app.title')}
        </h2>
        <p class="text-white/80 text-lg mb-8">
          {t('app.subtitle')}
        </p>

        <ul class="space-y-3 mb-10">
          {features.map(f => (
            <li class="flex items-center gap-3 text-white/90">
              <div class="w-6 h-6 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              {f}
            </li>
          ))}
        </ul>

        <div class="flex flex-wrap gap-3">
          <a
            href="#app-download"
            class="inline-flex items-center gap-3 px-6 py-3.5 bg-dark text-white font-semibold rounded-2xl hover:bg-gray-800 transition-colors"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-label="Apple" role="img">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <div class="text-left">
              <div class="text-xs opacity-70">Download on the</div>
              <div class="font-bold text-sm">App Store</div>
            </div>
          </a>
          <a
            href="#app-download"
            class="inline-flex items-center gap-3 px-6 py-3.5 bg-dark text-white font-semibold rounded-2xl hover:bg-gray-800 transition-colors"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-label="Google Play" role="img">
              <path d="M3.18 23.76c.38.21.82.22 1.24.04L14.66 12 4.42.2C4 .02 3.56.03 3.18.24 2.4.68 2 1.56 2 2.62v18.76c0 1.06.4 1.94 1.18 2.38zM16.54 13.38l-2.74-2.74L5.58 22.1l10.96-8.72zM21.5 10.5c-.42-.68-1.03-1.06-1.65-1.15l-2.23 1.15 2.66 2.66 1.22-.98c.73-.6.83-1.66 0-1.68zm-3.88-2.12l-2.66-2.66L5.58 1.9l8.22 8.22 3.82-1.74z"/>
            </svg>
            <div class="text-left">
              <div class="text-xs opacity-70">Get it on</div>
              <div class="font-bold text-sm">Google Play</div>
            </div>
          </a>
        </div>
      </div>

      <!-- App mockup -->
      <div class="flex justify-center">
        <div class="relative">
          <!-- Phone frame -->
          <div class="w-64 h-[500px] bg-dark rounded-[3rem] border-4 border-white/20 shadow-2xl flex flex-col overflow-hidden relative">
            <!-- Screen -->
            <div class="flex-1 bg-gradient-to-b from-primary-50 to-white p-5 pt-10">
              <!-- Status bar -->
              <div class="flex justify-between text-xs text-gray-400 mb-6">
                <span>9:41</span>
                <span>●●●</span>
              </div>

              <!-- App header -->
              <div class="flex items-center gap-2 mb-4">
                <div class="w-8 h-8 bg-primary-500 rounded-xl flex items-center justify-center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" aria-hidden="true">
                    <path d="M2 20c1.5 0 2.5-1 4-1s2.5 1 4 1"/>
                    <circle cx="9" cy="8" r="3"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs font-bold text-dark">Piscines Santanyí</div>
                  <div class="text-xs text-gray-400">Bon dia, Joan!</div>
                </div>
              </div>

              <!-- QR card -->
              <div class="bg-primary-500 rounded-2xl p-4 text-white mb-4">
                <div class="text-xs mb-2 opacity-80">Accés QR</div>
                <div class="w-16 h-16 bg-white rounded-xl mx-auto flex items-center justify-center">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="black" aria-hidden="true">
                    <rect x="3" y="3" width="7" height="7"/>
                    <rect x="14" y="3" width="7" height="7"/>
                    <rect x="3" y="14" width="7" height="7"/>
                    <rect x="5" y="5" width="3" height="3" fill="white"/>
                    <rect x="16" y="5" width="3" height="3" fill="white"/>
                    <rect x="5" y="16" width="3" height="3" fill="white"/>
                    <rect x="14" y="14" width="3" height="3"/>
                    <rect x="17" y="17" width="4" height="4"/>
                    <rect x="14" y="17" width="2" height="2" fill="white"/>
                  </svg>
                </div>
                <div class="text-center text-xs mt-2 opacity-80">Santanyí · Adult</div>
              </div>

              <!-- Next activity -->
              <div class="bg-white rounded-xl p-3 border border-gray-100">
                <div class="text-xs text-gray-400 mb-1">Propera activitat</div>
                <div class="font-semibold text-dark text-sm">Aqua-fitness</div>
                <div class="flex items-center gap-1 text-xs text-primary-600">
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                  Dimecres 9:00
                </div>
              </div>
            </div>

            <!-- Bottom nav -->
            <div class="bg-white border-t border-gray-100 px-6 py-3 flex justify-between">
              {['🏠', '📅', '🎫', '👤'].map(icon => (
                <div class="w-8 h-8 flex items-center justify-center rounded-lg text-lg">{icon}</div>
              ))}
            </div>
          </div>

          <!-- Floating badges -->
          <div class="absolute -right-4 top-20 bg-white rounded-xl shadow-xl px-3 py-2 text-sm font-semibold text-dark animate-float">
            📅 Reserva feta!
          </div>
          <div class="absolute -left-8 bottom-20 bg-emerald-500 text-white rounded-xl shadow-xl px-3 py-2 text-sm font-semibold animate-float" style="animation-delay: 1s;">
            ✅ Accés OK
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
