---
import { useTranslations, type Lang } from '../i18n/utils';
import horarisData from '../content/horaris.json';

interface Props {
  lang: Lang;
  compact?: boolean;
}

const { lang, compact = false } = Astro.props;
const t = useTranslations(lang);

const data = horarisData as any;
const temporada = data.temporada ?? '';
const rows = data.rows ?? [];

const activitats: any[] = data.activitats ?? [];
const logoMap: Record<string, string> = {};
activitats.forEach((a: any) => {
  if (a?.nom) {
    const logo = a.logo || '';
    logoMap[a.nom.toLowerCase()] = logo.startsWith('/') ? logo : logo ? `/images/${logo}` : '';
  }
});

const horaLabel = data.horaLabel || 'HORA';
const days = [
  { key: 'dilluns',   label: data.dayLabelDl || (lang === 'es' ? 'LUNES' : lang === 'en' ? 'MONDAY' : lang === 'de' ? 'MONTAG' : 'DILLUNS') },
  { key: 'dimarts',   label: data.dayLabelDm || (lang === 'es' ? 'MARTES' : lang === 'en' ? 'TUESDAY' : lang === 'de' ? 'DIENSTAG' : 'DIMARTS') },
  { key: 'dimecres',  label: data.dayLabelDc || (lang === 'es' ? 'MIÉRCOLES' : lang === 'en' ? 'WEDNESDAY' : lang === 'de' ? 'MITTWOCH' : 'DIMECRES') },
  { key: 'dijous',    label: data.dayLabelDj || (lang === 'es' ? 'JUEVES' : lang === 'en' ? 'THURSDAY' : lang === 'de' ? 'DONNERSTAG' : 'DIJOUS') },
  { key: 'divendres', label: data.dayLabelDv || (lang === 'es' ? 'VIERNES' : lang === 'en' ? 'FRIDAY' : lang === 'de' ? 'FREITAG' : 'DIVENDRES') },
  { key: 'dissabte',  label: data.dayLabelDs || (lang === 'es' ? 'SÁBADO' : lang === 'en' ? 'SATURDAY' : lang === 'de' ? 'SAMSTAG' : 'DISSABTE') },
];
---

{compact ? (
  <div class="bg-primary-50 rounded-2xl p-6 border border-primary-100">
    <h3 class="font-display font-semibold text-dark mb-4">{t('schedule.title')}</h3>
    {temporada && <p class="text-xs text-primary-600 font-medium mb-3">{temporada}</p>}
    <div class="overflow-x-auto rounded-2xl border border-gray-200 shadow-sm">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-primary-500 text-white">
            <th class="text-center px-3 py-2 font-bold">{horaLabel}</th>
            {days.map(d => <th class="text-center px-2 py-2 font-bold">{d.label}</th>)}
          </tr>
        </thead>
        <tbody>
          {rows.map((row: any, i: number) => (
            <tr class:list={['border-t border-gray-100', i % 2 === 0 ? 'bg-white' : 'bg-gray-50']}>
              <td class="px-3 py-2 font-bold text-dark text-center whitespace-nowrap">{row.hora}</td>
              {days.map(d => {
                const val = row[d.key] || '';
                const name = val.split('\n')[0]?.trim() || '';
                const logo = name ? logoMap[name.toLowerCase()] || '' : '';
                return (
                  <td class="text-center px-2 py-2 min-w-[80px]">
                    {name ? (
                      <div class="flex flex-col items-center gap-1">
                        {logo && <img src={logo} alt="" class="h-5 w-auto" loading="lazy" />}
                        <span class="font-semibold text-dark text-xs">{name}</span>
                      </div>
                    ) : <span class="text-gray-300">–</span>}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
) : (
  <section class="section bg-white" aria-labelledby="schedule-heading">
    <div class="container-site">
      <div class="text-center mb-12">
        <span class="badge-blue mb-3">{t('schedule.title')}</span>
        <h2 id="schedule-heading" class="section-title">{t('schedule.title')}</h2>
        <p class="section-subtitle">{t('schedule.subtitle')}</p>
        {temporada && <p class="text-sm text-primary-600 font-semibold mt-2">{temporada}</p>}
      </div>

      <div class="overflow-x-auto rounded-2xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
          <thead class="bg-primary-500 text-white">
            <tr>
              <th class="text-center px-3 py-3 font-bold rounded-tl-2xl whitespace-nowrap">{horaLabel}</th>
              {days.map((d, i) => (
                <th class:list={['text-center px-3 py-3 font-bold whitespace-nowrap', i === days.length - 1 ? 'rounded-tr-2xl' : '']}>{d.label}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {rows.map((row: any, i: number) => (
              <tr class:list={['border-t border-gray-100', i % 2 === 0 ? 'bg-white' : 'bg-gray-50']}>
                <td class="px-3 py-3 font-bold text-dark text-center whitespace-nowrap">{row.hora}</td>
                {days.map(d => {
                  const val = row[d.key] || '';
                  const name = val.split('\n')[0]?.trim() || '';
                  const logo = name ? logoMap[name.toLowerCase()] || '' : '';
                  return (
                    <td class="text-center px-2 py-3 min-w-[100px]">
                      {name ? (
                        <div class="flex flex-col items-center gap-1">
                          {logo && <img src={logo} alt="" class="h-7 w-auto" loading="lazy" />}
                          <span class="font-semibold text-dark text-xs">{name}</span>
                        </div>
                      ) : <span class="text-gray-300">–</span>}
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-6 p-4 bg-gray-50 rounded-xl text-sm text-gray-500 flex items-start gap-2">
        <svg class="w-4 h-4 text-primary-500 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span>
          {lang === 'en' ? 'Hours may vary on public holidays.' : lang === 'de' ? 'An Feiertagen können die Zeiten abweichen.' : lang === 'es' ? 'Los horarios pueden variar en festivos.' : 'Els horaris poden variar en festius.'}
        </span>
      </div>
    </div>
  </section>
)}
