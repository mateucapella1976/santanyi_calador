---
import { useTranslations, localePath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  variant?: 'section' | 'banner';
}

const { lang, variant = 'section' } = Astro.props;
const t = useTranslations(lang);
---

{variant === 'section' ? (
  <section class="section bg-white" aria-labelledby="daypass-heading">
    <div class="container-site">
      <div class="relative rounded-3xl overflow-hidden bg-gradient-to-br from-amber-400 via-orange-400 to-orange-500 p-10 md:p-16">
        <!-- Background pattern -->
        <div class="absolute inset-0 opacity-10">
          <svg width="100%" height="100%">
            <defs>
              <pattern id="dp-pattern" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
                <path d="M30 5 L55 30 L30 55 L5 30 Z" stroke="white" stroke-width="1" fill="none"/>
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#dp-pattern)"/>
          </svg>
        </div>

        <div class="relative z-10 flex flex-col md:flex-row items-center gap-10 md:gap-16">
          <!-- Icon -->
          <div class="flex-shrink-0">
            <div class="w-28 h-28 bg-white/20 backdrop-blur-sm rounded-3xl flex items-center justify-center border border-white/30">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true">
                <rect x="3" y="6" width="18" height="13" rx="2"/>
                <path d="M8 6V4m8 2V4M3 10h18"/>
                <path d="M8 14h.01M12 14h.01M16 14h.01"/>
              </svg>
            </div>
          </div>

          <!-- Content -->
          <div class="flex-1 text-center md:text-left">
            <span class="inline-flex items-center gap-1.5 bg-white/20 text-white text-xs font-bold px-3 py-1 rounded-full mb-3 uppercase tracking-wide">
              {t('daypass.badge')}
            </span>
            <h2 id="daypass-heading" class="font-display font-bold text-white text-3xl md:text-4xl mb-3">
              {t('daypass.title')}
            </h2>
            <p class="text-white/90 text-lg mb-6">
              {t('daypass.subtitle')}
            </p>

            <!-- Prices -->
            <div class="flex flex-wrap justify-center md:justify-start gap-4 mb-8">
              <div class="bg-white/20 backdrop-blur-sm rounded-2xl px-6 py-4 border border-white/30 text-center">
                <div class="font-display font-bold text-white text-3xl">5€</div>
                <div class="text-white/80 text-sm">{t('daypass.pool')}</div>
                <div class="text-white/60 text-xs">{t('daypass.perDay')}</div>
              </div>
              <div class="bg-white rounded-2xl px-6 py-4 text-center shadow-xl">
                <div class="font-display font-bold text-orange-500 text-3xl">8€</div>
                <div class="text-gray-700 text-sm font-medium">{t('daypass.poolGym')}</div>
                <div class="text-gray-400 text-xs">{t('daypass.perDay')}</div>
              </div>
            </div>

            <div class="text-white/80 text-sm mb-6">{t('daypass.includes')}</div>

            <div class="flex flex-wrap justify-center md:justify-start gap-3">
              <a href={localePath(lang, '/day-pass')} class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-orange-600 font-bold rounded-xl hover:bg-orange-50 transition-colors text-lg shadow-lg">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect x="3" y="6" width="18" height="13" rx="2"/>
                  <path d="M8 6V4m8 2V4M3 10h18"/>
                </svg>
                {t('daypass.cta')}
              </a>
              <a href="tel:+34673003828" class="inline-flex items-center gap-2 px-6 py-3.5 bg-white/20 text-white font-semibold rounded-xl hover:bg-white/30 transition-colors border border-white/30">
                {t('daypass.or')}
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
) : (
  <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 flex flex-col sm:flex-row items-center gap-4 justify-between">
    <div>
      <div class="font-display font-semibold text-amber-800 mb-1">{t('daypass.title')}</div>
      <div class="text-sm text-amber-600">{t('daypass.subtitle')}</div>
    </div>
    <a href={localePath(lang, '/day-pass')} class="flex-shrink-0 inline-flex items-center gap-2 px-5 py-2.5 bg-amber-500 text-white font-semibold rounded-xl hover:bg-amber-600 transition-colors">
      {t('daypass.cta')} – des de 5€
    </a>
  </div>
)}
