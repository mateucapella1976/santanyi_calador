---
import { useTranslations, localePath, type Lang } from '../i18n/utils';
import settings from '../content/settings.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const s = settings as any;
const phoneSantanyi   = s.phoneSantanyi   || '673 003 828';
const phoneCalaDor    = s.phoneCalaDor    || '673 008 715';
const emailSantanyi   = s.emailSantanyi   || 'piscinasantanyi@algaliasport.net';
const emailCalaDor    = s.emailCalaDor    || 'piscinacalador@algaliasport.net';
const instagram       = s.instagram       || 'https://www.instagram.com/piscinasantanyicalador/';
const facebook        = s.facebook        || 'https://www.facebook.com/piscinasantanyi';
const addressSantanyi = s.addressSantanyi || 'Carrer Bernat Vidal i Tomàs, 83, 07650 Santanyí';
const addressCalaDor  = s.addressCalaDor  || "Avinguda Sementer, S/N, 07691 Cala d'Or";
const rawLogoFooter = s.logoFooter || '';
const logoFooter = rawLogoFooter.startsWith('/') ? rawLogoFooter : rawLogoFooter ? `/images/${rawLogoFooter}` : '/logo-footer.png';
---

<footer class="text-white" style="background: #333333;">
  <div class="container-site py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href={localePath(lang, '/')} class="inline-block mb-4">
          <img src={logoFooter} alt="Piscines Santanyí Cala d'Or" class="h-16 w-auto" width="140" height="64" loading="lazy" />
        </a>
        <p class="text-gray-400 text-sm leading-relaxed mb-4">{t('footer.tagline')}</p>
        <div class="flex items-center gap-3">
          <a href={instagram} target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-white/10 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a href={facebook} target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-white/10 hover:bg-primary-500 rounded-lg flex items-center justify-center transition-colors" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Serveis -->
      <div>
        <h3 class="font-display font-semibold text-white mb-4 text-sm uppercase tracking-wider">{t('nav.swimming')} & {t('nav.gym')}</h3>
        <ul class="space-y-2.5 text-sm text-gray-400">
          <li><a href={localePath(lang, '/natacio')} class="hover:text-primary-400 transition-colors">{t('nav.swimming')}</a></li>
          <li><a href={localePath(lang, '/gimnas')} class="hover:text-primary-400 transition-colors">{t('nav.gym')}</a></li>
          <li><a href={localePath(lang, '/activitats')} class="hover:text-primary-400 transition-colors">{t('nav.activities')}</a></li>
          <li><a href={localePath(lang, '/padel')} class="hover:text-primary-400 transition-colors">{t('nav.padel')}</a></li>
          <li><a href={localePath(lang, '/entrenador-personal')} class="hover:text-primary-400 transition-colors">{t('services.personal.title')}</a></li>
        </ul>
      </div>

      <!-- Instal·lacions -->
      <div>
        <h3 class="font-display font-semibold text-white mb-4 text-sm uppercase tracking-wider">Instal·lacions</h3>
        <ul class="space-y-2.5 text-sm text-gray-400">
          <li><a href={localePath(lang, '/santanyi')} class="hover:text-primary-400 transition-colors">{t('nav.santanyi')}</a></li>
          <li><a href={localePath(lang, '/cala-dor')} class="hover:text-primary-400 transition-colors">{t('nav.calaDor')}</a></li>
          <li><a href={localePath(lang, '/preus')} class="hover:text-primary-400 transition-colors">{t('nav.prices')}</a></li>
          <li><a href={localePath(lang, '/horaris')} class="hover:text-primary-400 transition-colors">{t('nav.schedule')}</a></li>
          <li><a href={localePath(lang, '/day-pass')} class="hover:text-amber-400 transition-colors">Day Pass</a></li>
        </ul>
      </div>

      <!-- Contacte -->
      <div>
        <h3 class="font-display font-semibold text-white mb-4 text-sm uppercase tracking-wider">{t('nav.contact')}</h3>
        <ul class="space-y-3 text-sm text-gray-400">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-primary-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Santanyí: {addressSantanyi}</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-primary-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Cala d'Or: {addressCalaDor}</span>
          </li>
          <li>
            <a href={`tel:+34${phoneSantanyi.replace(/\s/g, '')}`} class="flex items-center gap-2 hover:text-primary-400 transition-colors">
              <svg class="w-4 h-4 text-primary-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.45a2 2 0 0 1 2-2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {phoneSantanyi}
            </a>
          </li>
          <li>
            <a href={`mailto:${emailSantanyi}`} class="flex items-center gap-2 hover:text-primary-400 transition-colors break-all">
              <svg class="w-4 h-4 text-primary-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              {emailSantanyi}
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-site py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <span>© {new Date().getFullYear()} Algàlia Esport SL · Piscines Municipals de Santanyí</span>
      <nav class="flex items-center gap-4" aria-label="Peu de pàgina">
        <a href={localePath(lang, '/privacitat')} class="hover:text-gray-300 transition-colors">{t('footer.links.privacy')}</a>
        <a href={localePath(lang, '/cookies')} class="hover:text-gray-300 transition-colors">{t('footer.links.cookies')}</a>
        <a href={localePath(lang, '/legal')} class="hover:text-gray-300 transition-colors">{t('footer.links.legal')}</a>
      </nav>
    </div>
  </div>
</footer>
