---
import Page from '../layouts/Page.astro';
import NewsletterPage from '../components/NewsletterPage';
import { getLangFromUrl, type Lang } from '../i18n/utils';
import client from '../../tina/__generated__/client';

const lang = getLangFromUrl(Astro.url) as Lang;
const res = await (client.queries as any).paginaNewsletter({ relativePath: 'pagina-newsletter.json' });
---

<Page
  title="Newsletter — Piscines Santanyí i Cala d'Or"
  description="Notícies i novetats de Piscines Santanyí i Cala d'Or"
  canonicalPath="/newsletter"
>
  <NewsletterPage
    client:load
    query={res.query}
    variables={res.variables}
    data={res.data}
    lang={lang}
  />
</Page>
